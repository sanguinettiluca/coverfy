// IMPORTANTE: Trabajen con la version 6.0.0 de prisma, ya que la 7.0.0 tiene cambios importantes y
// no es compatible con el codigo actual

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

// Admin seriamos nosotros, 
// Broker seria la empresa en si (ej. Aseguros),
// Sub-Broker son los empleados.
enum Role{
  ADMIN
  BROKER
  SUB_BROKER
}

model User{
  id String @id @default(uuid())
  email String @unique
  password String
  nombre String
  role Role

  // Si el usuario es un sub-broker, este campo referencia al broker al que pertenece
  brokerId String?
  subBrokers User[] @relation("BrokerSubBrokers")
  broker User? @relation("BrokerSubBrokers", fields: [brokerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TokenBlacklist {
  id String @id @default(uuid())
  token String
  createdAt DateTime @default(now())
}

