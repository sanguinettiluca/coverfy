// IMPORTANTE: Trabajen con la version 6.0.0 de prisma, ya que la 7.0.0 tiene cambios importantes y
// no es compatible con el codigo actual

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

// Admin seriamos nosotros, 
// Broker seria la empresa en si (ej. Aseguros),
// Sub-Broker son los empleados.
enum Role{
  ADMIN
  BROKER
  SUB_BROKER
}

model User{
  id String @id @default(uuid())
  email String @unique
  password String
  nombre String
  role Role

  // Si el usuario es un sub-broker, este campo referencia al broker al que pertenece
  brokerId String?
  broker User? @relation("BrokerSubBrokers", fields: [brokerId], references: [id])
  subBrokers User[] @relation("BrokerSubBrokers")

  companias CompaniaSeguros[]

  clientes Cliente[] @relation("BrokerClientes")

  // Auditoria: registros creados por el usuario:
  polizasCreadas Poliza[] @relation("PolizaCreador")
  clientesCreados Cliente[] @relation("ClienteCreador")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TokenBlacklist {
  id String @id @default(uuid())
  token String
  createdAt DateTime @default(now())
}

model Cliente{
  id String @id @default(uuid())
  nombres String
  apellidos String
  documento String
  fechaNacimiento DateTime?
  celular String
  celularAlternativo String?
  email String
  direccion String
  notas String?

  // Quien lo registro RELACION BROKER-CLIENTE:
  creadoPorId String
  creadoPor User @relation("ClienteCreador", fields: [creadoPorId], references: [id])

  brokerId String
  broker User @relation("BrokerClientes", fields: [brokerId], references: [id])

  // Polizas del cliente:
  polizas Poliza[]

  createdAt DateTime @default(now())
}

enum TipoSeguro{
  VEHICULO
  VIAJE
  ALQUILER
  HOGAR
  COMERCIO
  RESPONSABILIDAD_CIVIL
  FIANZA
  VIDA
  OTROS
}

enum EstadoPoliza{
  ACTIVA
  VENCIDA
  CANCELADA
  SUSPENDIDA
}

enum MetodoPago{
  Debito
  Credito
  Transferencia
  Efectivo
}

model CompaniaSeguros{
  id String @id @default(uuid())
  nombre String

  brokerId String
  broker User @relation(fields: [brokerId], references: [id])
  
  polizas Poliza[]
  createdAt DateTime @default(now())
}

model Poliza{
  id String @id @default(uuid())
  numeroPoliza String @default("")
  tipoSeguro TipoSeguro
  estado EstadoPoliza @default(ACTIVA)
  fechaInicio DateTime?
  fechaVencimiento DateTime?
  montoTotal Float @default(0)
  cuotas Int @default(1)
  metodoPago MetodoPago @default(Debito)

  // Relacion con cliente:
  // La relacion es del campo clienteId que hace referencia al campo id de la tabla Cliente, y si 
  // se borra el cliente, se borran sus polizas (Cascade):
  clienteId String
  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  companiaId String
  compania CompaniaSeguros @relation(fields: [companiaId], references: [id])

  // Quien registro la poliza:
  creadoPorId String
  creadoPor User @relation("PolizaCreador", fields: [creadoPorId], references: [id])

  // Relacion 1:1 con cada tabla de detalle por tipo de seguro:
  // Solo una de estas relaciones se llenara dependiendo del tipo de seguro:
  detalleVehiculo DetalleVehiculo?
  detalleViaje DetalleViaje?
  detalleAlquiler DetalleAlquiler?
  detalleHogar DetalleHogar?
  detalleComercio DetalleComercio?
  detalleResponsabilidadCivil DetalleResponsabilidadCivil?
  detalleFianza DetalleFianza?
  detalleVida DetalleVida?
  detalleOtros DetalleOtros?

  documentos Documento[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Tipos de seguro:
model DetalleVehiculo{
  id String @id @default(uuid())
  polizaId String @unique
  poliza Poliza @relation(fields: [polizaId], references: [id], onDelete: Cascade)
  marca String
  modelo String
  anio Int?
  matricula String @default("")
  padron String @default("")
  chasis String @default("")
  motor String @default("")
}

model DetalleViaje{
  id String @id @default(uuid())
  polizaId String @unique
  poliza Poliza @relation(fields: [polizaId], references: [id], onDelete: Cascade)
  destino String
  fechaSalida DateTime?
  fechaRegreso DateTime?
  pasajeros Int?
}

model DetalleAlquiler{
  id String @id @default(uuid())
  polizaId String @unique
  poliza Poliza @relation(fields: [polizaId], references: [id], onDelete: Cascade)
  direccion String @default("")
  tipoInmueble String @default("")
  valorAlquiler Float @default(0)
}

model DetalleHogar{
  id String @id @default(uuid())
  polizaId String @unique
  poliza Poliza @relation(fields: [polizaId], references: [id], onDelete: Cascade)
  direccion String @default("")
  tipoConstruccion String @default("")
  metrosCuadrados Int?
  valorPropiedad Float @default(0)
}

model DetalleComercio{
  id String @id @default(uuid())
  polizaId String @unique
  poliza Poliza @relation(fields: [polizaId], references: [id], onDelete: Cascade)
  razonSocial String @default("")
  rubro String @default("")
  direccion String @default("")
}

model DetalleResponsabilidadCivil{
  id String @id @default(uuid())
  polizaId String @unique
  poliza Poliza @relation(fields: [polizaId], references: [id], onDelete: Cascade)
  actividad String @default("")
  limiteCobertura Float @default(0)
}

model DetalleFianza{
  id String @id @default(uuid())
  polizaId String @unique
  poliza Poliza @relation(fields: [polizaId], references: [id], onDelete: Cascade)
  tipoFianza String @default("")
  montoGarantizado Float @default(0)
  beneficiario String @default("")
}

model DetalleVida{
  id String @id @default(uuid())
  polizaId String @unique
  poliza Poliza @relation(fields: [polizaId], references: [id], onDelete: Cascade)
  sumaAsegurada Float @default(0)
  beneficiario String @default("")
}

model DetalleOtros{
  id String @id @default(uuid())
  polizaId String @unique
  poliza Poliza @relation(fields: [polizaId], references: [id], onDelete: Cascade)
  descripcion String @default("")
}

// Documentos:
model Documento{
  id String @id @default(uuid())
  nombre String
  tipo String
  url String

  polizaId String
  poliza Poliza @relation(fields: [polizaId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}